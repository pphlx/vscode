{
  "information_for_contributors": [
    "This file has been converted from https://github.com/KapitanOczywisty/language-php/blob/master/grammars/html.cson",
    "If you want to provide a fix or improvement, please create a pull request against the original repository.",
    "Once accepted there, we are happy to receive an update request."
  ],
  "version": "https://github.com/KapitanOczywisty/language-php/commit/ff64523c94c014d68f5dec189b05557649c5872a",
  "name": "PPHLX",
  "scopeName": "text.html.pphx",
  "injections": {
    "L:meta.embedded.php.blade": {
      "patterns": [
        {
          "include": "text.html.basic"
        },
        {
          "include": "text.html.php.blade#blade"
        }
      ]
    },
    "text.html.pphx - (meta.embedded | meta.tag), L:((text.html.pphx meta.tag) - (meta.embedded.block.php | meta.embedded.line.php)), L:(source.js - (meta.embedded.block.php | meta.embedded.line.php)), L:(source.css - (meta.embedded.block.php | meta.embedded.line.php))": {
      "patterns": [
        {
          "include": "#php-tag"
        }
      ]
    }
  },
  "patterns": [
    {
      "comment": "PPHLX import directives: @import Name from 'path'",
      "match": "^\\s*(@import)\\s+([A-Z][a-zA-Z0-9_]*)\\s+(from)\\s+(['\"])([^'\"]+)\\4",
      "captures": {
        "1": { "name": "keyword.control.import.pphx" },
        "2": { "name": "entity.name.class.pphx" },
        "3": { "name": "keyword.control.from.pphx" },
        "4": { "name": "string.quoted.single.pphx" },
        "5": { "name": "string.quoted.single.pphx" }
      }
    },
    {
      "begin": "\\A#!",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.php"
        }
      },
      "end": "$",
      "name": "comment.line.shebang.php"
    },
    {
      "include": "text.html.derivative"
    }
  ],
  "repository": {
    "php-tag": {
      "patterns": [
        {
          "begin": "\\{\\|(=)?",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.embedded.begin.php"
            }
          },
          "end": "\\|\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.embedded.end.php"
            }
          },
          "name": "meta.embedded.block.php",
          "contentName": "source.php",
          "patterns": [
            {
              "include": "source.php"
            }
          ]
        },
        {
          "begin": "<\\?(?i:php|=)?(?![^?]*\\?>)",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.embedded.begin.php"
            }
          },
          "end": "(\\?)>",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.embedded.end.php"
            },
            "1": {
              "name": "source.php"
            }
          },
          "name": "meta.embedded.block.php",
          "contentName": "source.php",
          "patterns": [
            {
              "include": "source.php"
            }
          ]
        },
        {
          "begin": "<\\?(?i:php|=)?",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.embedded.begin.php"
            }
          },
          "end": "(\\?)>",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.embedded.end.php"
            },
            "1": {
              "name": "source.php"
            }
          },
          "name": "meta.embedded.line.php",
          "contentName": "source.php",
          "patterns": [
            {
              "include": "source.php"
            }
          ]
        }
      ]
    }
  }
}